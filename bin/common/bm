def print_usage(io, executor, commands = nil)
  runner = File.basename($0)
  io.printf("Usage: %s (%s) [option]\n", runner, executor.get_command_names.join('|'))
  executor.get_command_names_and_details.each do |obj|
    if commands.nil? || commands.include?(obj[:name])
      io.printf("  %s %s %s\n", runner, obj[:name], obj[:option])
      io.printf("%s\n", obj[:details].map{ |x| '    ' + x }.join("\n"))
    end
  end
end

def print_error(io, executor, first_message, e, commands = nil)
  io.printf("%s\n", first_message)
  io.printf("%s\n", e.message) unless e.message.empty?
  print_usage(io, executor, commands)
end

executor = Executor.new(Config.new(Command::KEY_INDEX))

if ARGV.length < 1
  print_usage($stderr, executor)
  exit 1
end

command = ARGV[0]
options = ARGV[1..-1]

begin
  executor.execute(command, options)
rescue InvalidCommandError => e
  message = sprintf("[ERROR] Unknown command: %s", command)
  print_error($stderr, executor, message, e)
  exit 1
rescue InvalidArgumentError => e
  message = sprintf("[ERROR] Invalid Argument: %s: %s", command, options.join(' '))
  print_error($stderr, executor, message, e, [command])
  exit 1
rescue DuplicateError => e
  message = sprintf("[ERROR] Duplicated : %s", command)
  print_error($stderr, executor, message, e, [command])
  exit 1
rescue NoExistedError => e
  message = sprintf("[ERROR] No existed : %s", command)
  print_error($stderr, executor, message, e, [command])
  exit 1
end

