## Executor {{{
class Executor
  CLASS_NAMES = ['ListCommand', 'RegCommand', 'RmCommand', 'ShowCommand', 'RenameCommand', 'RefreshCommand', 'CloneCommand']

  def initialize(config)
    @config = config
    @commands = []
    CLASS_NAMES.each do |class_name|
      @commands << Kernel.const_get(class_name).new(@config)
    end
  end

  def get_command_names()
    get_command_names_and_details().map do |obj|
      obj[:name]
    end
  end

  def get_command_names_and_details()
    @commands.map do |command|
      { name: command.get_name,
        option: command.get_optional_description,
        details: command.get_command_details }
    end
  end

  def execute(command_name, options)
    message = target(command_name).execute(options)
    return if message.nil?
    printf("%s\n", message)
  end

  protected

  def target(command_name)
    @commands.each do |command|
      return command if command.target?(command_name)
    end
    raise InvalidCommandError.new
  end
end
