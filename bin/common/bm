class Config
  require 'fileutils'
  require 'json'

  INDEX_STEP = 10
  DEFAULT_CONFIG_PATH = '~/.bm/config'
  CONFIG_PATH = ENV['BM_CONFIG'] || DEFAULT_CONFIG_PATH

  def initialize(key_index, path = CONFIG_PATH)
    @key_index = key_index
    @path = File.expand_path(path)
    prepare()
    @values = load_config()
  end

  attr_reader :key_index

  def exist?(identity)
    !(@values[identity].nil?)
  end

  def list()
    @values.sort do |(k1, v1), (k2, v2)|
      v1[key_index] <=> v2[key_index]
    end.map do |v|
      v[1].delete(key_index)
      v
    end
  end

  def get(identity, key = nil)
    results = @values[identity]
    return if results.nil?
    return results if key.nil?
    results[key]
  end

  def register(identity, infos)
    raise DuplicateError.new(sprintf("%s is existed", identity)) if exist?(identity)
    index = get_max_index
    infos[key_index] = index.to_i + INDEX_STEP
    @values[identity] = infos
    save_config()
  end

  def rm(identity)
    @values.delete(identity)
    save_config()
  end

  def index_refresh()
    @values.sort do |(k1, v1), (k2, v2)|
      v1[key_index] <=> v2[key_index]
    end.map.with_index do |v, index|
      v[1][key_index] = (index + 1) * INDEX_STEP
      [v[0], v[1]]
    end
    save_config()
  end

  protected

  def prepare()
    return if File.exist?(@path)

    FileUtils.mkdir_p(File.dirname(@path))
    #FileUtils.touch(@path)
    open(@path, 'w') do |io|
      io.printf('{}')
    end
  end

  def load_config()
    open(@path) do |io|
      JSON.load(io)
    end
  end

  def save_config()
    open(@path, 'w') do |io|
      #JSON.dump(@values, io)
      io.write(JSON.pretty_generate(@values))
    end
  end

  def get_max_index()
    max = @values.sort do |(k1, v1), (k2, v2)|
      v1[key_index] <=> v2[key_index]
    end[-1]
    return 0 if max.nil?
    max[1][key_index]
  end
end
