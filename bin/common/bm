## Command definition {{{
class Command
  KEY_INDEX = 'index'
  KEY_PATH = 'path'

  def initialize(config, name)
    @config = config
    @name = name
  end

  def execute(options)
    raise 'Not implemented'
  end

  def get_command_details()
    raise 'Not implemented'
  end

  def get_optional_description()
    raise 'Not implemented'
  end

  def get_name()
    @name
  end

  def target?(name)
    (name == @name)
  end

  protected

  def get_config()
    @config
  end
end

class ListCommand < Command
  def initialize(config)
    super(config, 'list')
  end

  def get_command_details()
    ['show bookmarks']
  end

  def get_optional_description()
    ''
  end

  def execute(_options)
    values = get_config.list()
    max_length = values.map{|x| x[0].length}.max
    values.map do |value|
      #sprintf("%-20s: %s", value[0], value[1][KEY_PATH])
      sprintf("%s: %s", value[0].ljust(max_length+1), value[1][KEY_PATH])
    end.join("\n")
  end
end

class RegCommand < Command
  def initialize(config)
    super(config, 'reg')
  end

  def get_command_details()
    results = []
    results << 'register bookmark'
    results << 'If identity is null identity will be the current directory name.'
    results << 'If path is null path will be the current directory.'
    results
  end

  def get_optional_description()
    '[identity] [path]'
  end

  def execute(options)
    #raise InvalidArgumentError.new('identity is required') if options.length < 1
    identity = options[0] # identityはオプション
    if identity.nil?
      identity = Dir.pwd.split('/')[-1]
    end

    path = options[1] # pathはオプション
    if path.nil?
      path = Dir.pwd
    else
      path = File.expand_path(path)
    end

    get_config.register(identity, {KEY_PATH => path})
    sprintf("%s is registered", identity)
  end
end

class RmCommand < Command
  def initialize(config)
    super(config, 'rm')
  end

  def get_command_details()
    ['remove bookmark']
  end

  def get_optional_description()
    'identity'
  end

  def execute(options)
    raise InvalidArgumentError.new('identity is required') if options.length < 1
    identity = options[0]

    raise NoExistedError.new(sprintf("%s is not existed", identity)) unless get_config.exist?(identity)

    get_config.rm(identity)
    get_config.index_refresh()
    sprintf("%s is removed", identity)
  end
end

class ShowCommand < Command
  def initialize(config)
    super(config, 'show')
  end

  def get_command_details()
    ['show path']
  end

  def get_optional_description()
    'identity'
  end

  def execute(options)
    raise InvalidArgumentError.new('identity is required') if options.length < 1
    identity = options[0]

    raise NoExistedError.new(sprintf("%s is not existed", identity)) unless get_config.exist?(identity)
    get_config.get(identity, KEY_PATH)
  end
end

class RenameCommand < Command
  def initialize(config)
    super(config, 'mv')
  end

  def get_command_details()
    results = []
    results << 'rename identity'
    results
  end

  def get_optional_description()
    'old_identity new_identity'
  end

  def execute(options)
    raise InvalidArgumentError.new('old_identity and new_identity are required') if options.length < 2
    old_identity = options[0]
    new_identity = options[1]

    raise NoExistedError.new(sprintf("%s is not existed", old_identity)) unless get_config.exist?(old_identity)
    show_command = ShowCommand.new(get_config)
    path = show_command.execute([old_identity])

    reg_command = RegCommand.new(get_config)
    reg_command.execute([new_identity, path])

    rm_command = RmCommand.new(get_config)
    rm_command.execute([old_identity])

    sprintf("Renamed %s to %s", old_identity, new_identity)
  end
end

class RefreshCommand < Command
  def initialize(config)
    super(config, 'refresh')
  end

  def get_command_details()
    results = []
    results << 'refresh bookmark'
    results
  end

  def get_optional_description()
    ''
  end

  def execute(options)
    get_config.index_refresh()
    return
  end
end

class CloneCommand < Command
  def initialize(config)
    super(config, 'clone')
  end

  def get_command_details()
    results = []
    results << 'git clone and register bookmark'
    results << 'If identity is null identity will be git repository name'
    results
  end

  def get_optional_description()
    'git_url [identity]'
  end

  def execute(options)
    raise InvalidArgumentError.new('giturl is required') if options.length < 1
    giturl = options[0]
    identity = options[1]

    run = sprintf("git clone %s", giturl)
    system(run)

    basename = giturl.split('/')[-1].sub(/.git$/, '')
    path = sprintf("%s/%s", Dir.pwd, basename)

    if identity.nil?
      identity = basename
    end

    reg_command = RegCommand.new(get_config)
    reg_options = []
    reg_options << identity
    reg_options << path
    reg_command.execute(reg_options)
    sprintf("%s is cloned and registered", identity)
  end
end
