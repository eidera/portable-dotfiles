#!/bin/bash

####
# インタラクティブシェルではない環境(Ex. Alfred, KeyboardMaestro, ...)でnodejs on miseのグローバルインストールされた環境を実行するツール
# 
# Preparation
#   cp ~/bin/anode /usr/local/bin/.
# 
# Execution
#   anode npm ls -g # <- `npm ls -g`
#   anode node example.js
#   anode tsx example.ts

if [ -z "$1" ] ; then
  echo 1>&2 "Usage: $0 {node related command} {argument...}"
  exit 1
fi

MISE_SEARCH_PATHS=("$HOME/.local/bin/mise" "/opt/homebrew/bin/mise")

MISE=""
for p in "${MISE_SEARCH_PATHS[@]}"; do
  [ -x "$p" ] && MISE="$p" && break
done

if [ -z "$MISE" ]; then
  echo 1>&2 "mise not found"
  exit 1
fi

export NODE_PATH=$("$MISE" exec -- npm root -g)
exec "$MISE" exec -- "$@"
